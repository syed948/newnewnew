# ---- Core app ----
# A managed Postgres connection string. Any of these work:
#   - Vercel Postgres (Storage tab in your Vercel project -> creates this automatically)
#   - Neon (https://neon.tech) - use the pooled connection string
#   - Supabase (https://supabase.com) - use the "Transaction" pooler string, port 6543
DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# Any long random string. Generate one with: openssl rand -hex 32
JWT_SECRET=

# The exact public URL this app is served at - used to build Twilio webhook URLs
# and (optionally) to validate Twilio's request signature.
APP_BASE_URL=https://dialer.brandigade.com

# Comma-separated list of origins allowed to call the API (for CORS).
ALLOWED_ORIGINS=https://dialer.brandigade.com,https://brandigade.com

# Set to "true" once your Voice/Messaging webhook URLs in the Twilio Console exactly
# match APP_BASE_URL, to enforce X-Twilio-Signature verification on webhooks.
TWILIO_VALIDATE_SIGNATURE=false

# ---- Bootstrap admin (only used the first time the database has no admin yet) ----
BOOTSTRAP_ADMIN_EMAIL=admin@brandigade.com
BOOTSTRAP_ADMIN_PASSWORD=change-me-immediately

# ---- Twilio ----
# These can also be entered later from the Admin Panel > Settings screen once deployed;
# setting them here just pre-fills the database on first boot.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_TWIML_APP_SID=
TWILIO_CALLER_ID=
